# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.uv/
*.egg-info/
dist/
build/

# Ambiente
.env

# Dados — nunca versionar dados brutos, processados ou artefatos gerados
data/
*.csv
*.parquet
*.feather

# Modelos — armazenados no MLflow/MinIO, não no git
models/
*.pkl
*.joblib
*.onnx

# Notebooks — outputs podem ter dados sensíveis
notebooks/.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Coverage e type checking
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# MLflow local (caso rode sem Docker)
mlruns/
mlartifacts/

# Airflow — logs e banco local gerados em runtime
airflow/logs/
airflow/*.db

# Feast — artefatos gerados (registry, online store, parquet de features)
data/feast/

# Evidently — relatórios de drift gerados em runtime
*.html
*.json
!pyproject.toml
!**/docker-compose*.yml

# Bancos SQLite gerados localmente
*.db
*.sqlite

# Artefatos de treinamento gerados localmente (plots, confusion matrix)
data/artifacts/

# Logs genéricos
*.log

# Segredos e certificados — nunca versionar
*.pem
*.key
secrets/

# Material de divulgação e entrevistas — não faz parte do projeto
docs/linkedin/
docs/interview-guide.html
docs/mapa-estudo.html
docs/mapa-sprints.html
